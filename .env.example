# DeepSeek API (OpenAI-compatible)
DEEPSEEK_API_KEY="sk-xxx"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-v4-flash"

# Database (SQLite — auto-managed by Prisma)
DATABASE_URL="file:./prisma/noteflow.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-string"

# Tencent COS (optional, for file uploads)
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET=""
COS_REGION="ap-guangzhou"
COS_CDN_DOMAIN=""

# Transcription Pipeline (Python —阿里云 DashScope + OSS)
# Required for video/audio download + transcription
DASHSCOPE_API_KEY=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET_NAME=""
OSS_ENDPOINT=""
FFMPEG_PATH=""
